{
  "rewrites": [
    { "source": "/dashboard", "destination": "https://api.nohuman.live/humanprox" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
